@model List<MaintenanceRequest>

@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Student Dashboard</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <style>
        body {
            margin: 0;
            font-family: 'Segoe UI', sans-serif;
            background-color: #f4f6fb;
        }

        .container-fluid {
            display: flex;
            height: 100vh;
        }

        /* Sidebar */
        .sidebar {
            width: 250px;
            background-color: #1e3c72;
            color: white;
            padding: 20px;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
        }

            .sidebar h4 {
                font-weight: 600;
            }

        .menu {
            margin-top: 30px;
        }

            .menu a {
                display: block;
                padding: 10px 15px;
                border-radius: 8px;
                color: white;
                text-decoration: none;
                margin-bottom: 10px;
            }

                .menu a.active {
                    background-color: white;
                    color: #1e3c72;
                }

        .logout-btn {
            background-color: #6c2bd9;
            border: none;
            border-radius: 8px;
            padding: 10px;
            color: white;
        }

        /* Main Content */
        .main-content {
            flex: 1;
            padding: 30px;
        }

            .main-content h2 {
                font-weight: 600;
                color: #1e3c72;
            }

        .table-card {
            background: white;
            padding: 20px;
            border-radius: 15px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        }

        table {
            width: 100%;
        }

        th {
            font-size: 14px;
        }

        /* Status badges */
        .badge-approved {
            background-color: #d1fae5;
            color: #059669;
            padding: 5px 10px;
            border-radius: 15px;
        }

        .badge-pending {
            background-color: #fef3c7;
            color: #b45309;
            padding: 5px 10px;
            border-radius: 15px;
        }
    </style>
</head>

<body>

    <div class="container-fluid">

        <!-- Sidebar -->
        <div class="sidebar">

            <div>
                <h4>Student Portal</h4>
                <p style="font-size:13px;">Maintenance system</p>

                <div class="menu">
                    <a href="/Student/SubmitRequest">+ Submit Request</a>
                    <a href="/Student/StudentDashboard" class="active">My Requests</a>
                </div>
            </div>

            <a href="/Account/Logout" class="logout-btn text-center d-block">
                Logout
            </a>
        </div>

        <!-- Main Content -->
        <div class="main-content">
            <h2>My Maintenance Requests</h2>
            <p class="text-muted">Track the status of your submitted requests</p>

            <div class="table-card mt-4">
                <table class="table">
                    <thead>
                        <tr>
                            <th>Request ID</th>
                            <th>Issue Type</th>
                            <th>Room No</th>
                            <th>Status</th>
                            <th>Date</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.RequestId</td>
                                <td>@item.IssueType</td>
                                <td>@item.RoomNo</td>

                                <td>
                                    @if (item.Status == "Approved")
                                    {
                                        <span class="badge-approved">Approved</span>
                                    }
                                    else if (item.Status == "Rejected")
                                    {
                                        <span class="badge bg-danger">Rejected</span>
                                    }
                                    else
                                    {
                                        <span class="badge-pending">Pending</span>
                                    }
                                </td>

                                <td>@item.Date.ToShortDateString()</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

        </div>

    </div>

</body>
</html>